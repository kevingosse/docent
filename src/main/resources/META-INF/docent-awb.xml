<idea-plugin>
    <!-- Loaded only when com.intellij.agent.workbench is present (see plugin.xml's optional <depends>).
         Installs the Docent's workbench seams (session directory + push notifier) at project open so the
         "Connect agent…" UI and the review push path are available whenever the workbench is present.

         NB: we do NOT enable the AWB direct-HTTP MCP path (agent.workbench.mcp.use.direct.http). It defaults
         to false → the agent reaches the IDE MCP server via the user's .mcp.json (ij-proxy stdio), which is the
         working path here and is exempt from Claude Code's 60s HTTP first-byte timeout. See DocentWorkbenchSetup. -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- ProjectActivity. The EP is `postStartupActivity` (interface ProjectActivity) — there is NO
             `startupActivity` EP in the platform (262: only postStartupActivity / backgroundPostStartupActivity),
             so the old `<startupActivity>` tag registered against a non-existent EP and silently never ran. -->
        <postStartupActivity implementation="com.kevingosse.docent.awb.DocentWorkbenchSetup"/>
    </extensions>

    <!-- Inject the Docent protocol into a workbench-launched agent's system prompt at launch, so it knows
         the docent_* tools exist and when to use them without the human prompting it (see
         DocentLaunchContributor). -->
    <extensions defaultExtensionNs="com.intellij.agent.workbench">
        <sessionLaunchContributor implementation="com.kevingosse.docent.awb.DocentLaunchContributor"/>
    </extensions>
</idea-plugin>
